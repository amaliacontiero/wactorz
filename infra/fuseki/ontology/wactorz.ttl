# Wactorz ontology — Turtle (TTL) format
#
# This file defines the RDF vocabulary for Wactorz agents, messages, and events.
# Loaded into Fuseki dataset "wactorz" on startup (future: via Fuseki config.ttl).
#
# Planned additions:
#   - SHACL shapes for agent configuration validation
#   - HSML (Hybrid Sensor Markup Language) terms for IoT/HA sensor data
#   - OWL axioms for agent type hierarchy

@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix af:    <https://waldiez.github.io/wactorz/ontology#> .

# ── Ontology declaration ──────────────────────────────────────────────────────

<https://waldiez.github.io/wactorz/ontology>
    a owl:Ontology ;
    dcterms:title "Wactorz Ontology" ;
    dcterms:description "Vocabulary for Wactorz multi-agent actor model" ;
    owl:versionInfo "0.1.0" .

# ── Agent types ───────────────────────────────────────────────────────────────

af:Agent
    a owl:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "An Wactorz actor (base class)" .

af:MainActor
    a owl:Class ;
    rdfs:subClassOf af:Agent ;
    rdfs:label "MainActor" ;
    rdfs:comment "The central LLM orchestrator agent" .

af:DynamicAgent
    a owl:Class ;
    rdfs:subClassOf af:Agent ;
    rdfs:label "DynamicAgent" ;
    rdfs:comment "An agent whose behaviour is defined by a runtime-generated script" .

af:MonitorAgent
    a owl:Class ;
    rdfs:subClassOf af:Agent ;
    rdfs:label "MonitorAgent" ;
    rdfs:comment "A protected health-monitoring agent" .

af:MlAgent
    a owl:Class ;
    rdfs:subClassOf af:Agent ;
    rdfs:label "MlAgent" ;
    rdfs:comment "An agent that runs ML inference" .

# ── Agent properties ──────────────────────────────────────────────────────────

af:agentId
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:string ;
    rdfs:label "agent UUID" .

af:agentName
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:string ;
    rdfs:label "human-readable agent name" .

af:agentState
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:string ;
    rdfs:label "lifecycle state (initializing|running|paused|stopped|failed)" .

af:isProtected
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:boolean ;
    rdfs:label "whether the agent is protected from external termination" .

# ── Message types ─────────────────────────────────────────────────────────────

af:Message
    a owl:Class ;
    rdfs:label "Message" ;
    rdfs:comment "A typed message exchanged between agents" .

af:messageId     a owl:DatatypeProperty ; rdfs:domain af:Message ; rdfs:range xsd:string .
af:fromAgent     a owl:ObjectProperty   ; rdfs:domain af:Message ; rdfs:range af:Agent .
af:toAgent       a owl:ObjectProperty   ; rdfs:domain af:Message ; rdfs:range af:Agent .
af:timestampMs   a owl:DatatypeProperty ; rdfs:domain af:Message ; rdfs:range xsd:long .
af:messageType   a owl:DatatypeProperty ; rdfs:domain af:Message ; rdfs:range xsd:string .

# ── Channel — MQTT pub/sub topic contract ─────────────────────────────────────
# Models what each agent publishes and subscribes to (from TopicContract in
# core/topic_bus.py). Stored in urn:wactorz:channels, populated by
# AgentManifestBridge whenever an agent publishes agents/{id}/manifest.
#
# SPARQL "who listens to HA state changes?":
#   SELECT ?agent WHERE {
#     ?agent af:subscribesTo ?ch .
#     ?ch af:channelTopic ?t .
#     FILTER(STRSTARTS(?t, "home/state"))
#   }
#
# SPARQL "auto-wireable pairs (producer → consumer via shared channel)":
#   SELECT ?producer ?consumer ?topic WHERE {
#     ?producer af:publishesTo ?ch .
#     ?consumer af:subscribesTo ?ch .
#     ?ch af:channelTopic ?topic .
#     FILTER(?producer != ?consumer)
#   }

af:Channel
    a owl:Class ;
    rdfs:label "Channel" ;
    rdfs:comment "An MQTT topic or data stream pattern that agents publish to or subscribe from" .

af:channelTopic
    a owl:DatatypeProperty ;
    rdfs:domain af:Channel ;
    rdfs:range xsd:string ;
    rdfs:label "MQTT topic pattern (may contain # and + wildcards)" .

af:declaredSchema
    a owl:DatatypeProperty ;
    rdfs:domain af:Channel ;
    rdfs:range xsd:string ;
    rdfs:label "Declared payload schema (JSON, from spawn config produces_schema / consumes_schema)" .

af:observedSchema
    a owl:DatatypeProperty ;
    rdfs:domain af:Channel ;
    rdfs:range xsd:string ;
    rdfs:label "Runtime-observed payload field names and types (authoritative over declaredSchema)" .

af:observedExample
    a owl:DatatypeProperty ;
    rdfs:domain af:Channel ;
    rdfs:range xsd:string ;
    rdfs:label "Example payload captured from a real publish() call" .

af:triggersWhen
    a owl:DatatypeProperty ;
    rdfs:domain af:Channel ;
    rdfs:range xsd:string ;
    rdfs:label "JSON conditions that cause the subscribing agent to act (from TopicContract.triggers_when)" .

# Agent ↔ Channel relationships

af:publishesTo
    a owl:ObjectProperty ;
    rdfs:domain af:Agent ;
    rdfs:range af:Channel ;
    rdfs:label "agent produces data on this channel" .

af:subscribesTo
    a owl:ObjectProperty ;
    rdfs:domain af:Agent ;
    rdfs:range af:Channel ;
    rdfs:label "agent consumes data from this channel" .

# ── Agent runtime metrics ──────────────────────────────────────────────────────
# Upserted by MetricsBridge whenever agents/{id}/metrics is published on MQTT.
# Enables queries like "which agent has the most errors?" or "total LLM cost?".

af:messagesProcessed
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:integer ;
    rdfs:label "total messages processed since spawn" .

af:errorsCount
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:integer ;
    rdfs:label "total errors encountered since spawn" .

af:tasksCompleted
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:integer ;
    rdfs:label "number of tasks successfully completed" .

af:tasksFailed
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:integer ;
    rdfs:label "number of tasks that failed" .

af:restartCount
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:integer ;
    rdfs:label "number of times this agent has been restarted" .

af:costUsd
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:decimal ;
    rdfs:label "cumulative LLM inference cost in USD" .

af:metricsUpdatedAt
    a owl:DatatypeProperty ;
    rdfs:domain af:Agent ;
    rdfs:range xsd:dateTime ;
    rdfs:label "timestamp of last metrics snapshot" .

# ── SHACL shapes (planned) ────────────────────────────────────────────────────
# TODO: add sh:NodeShape for af:Agent, af:Message, af:DynamicAgent (script validation)
