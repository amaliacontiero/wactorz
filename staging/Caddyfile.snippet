# Add this block to your existing Caddyfile on the VM.
# Replace staging.yourdomain.com with your actual (sub)domain or VM IP.

staging.yourdomain.com {
    # WebSocket upgrade for MQTT-over-WS and /ws paths
    @ws {
        header Connection *Upgrade*
        header Upgrade    websocket
    }
    reverse_proxy @ws localhost:8888
    reverse_proxy localhost:8888
}
