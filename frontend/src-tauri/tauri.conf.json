{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wactorz",
  "version": "0.4.1",
  "identifier": "io.waldiez.wactorz",
  "build": {
    "frontendDist": "../../static/app",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
