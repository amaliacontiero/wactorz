{
  "name": "wactorz-dashboard",
  "version": "0.4.2",
  "description": "Wactorz 3D live dashboard — Babylon.js + MQTT",
  "private": true,
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "fmt": "bun x prettier --write --list-different \"src/**/*.ts\"",
    "format": "bun fmt",
    "docs": "typedoc --out ../site/api/js --entryPointStrategy expand src --name \"Wactorz JS\" --readme none --hideGenerator",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@babylonjs/core": "^8.55.1",
    "@babylonjs/gui": "^8.55.1",
    "@babylonjs/loaders": "^8.55.1",
    "@waldiez/wid": "github:waldiez/wid",
    "mqtt": "^5.15.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.9.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.7"
  }
}
